#!/usr/bin/env python3
"""Move files to the user Trash without permanent deletion."""

from __future__ import annotations

import argparse
from contextlib import contextmanager
from datetime import datetime, timezone
import fcntl
import os
from pathlib import Path
import shutil
import sys
import tempfile
from urllib.parse import quote


def trash_root() -> Path:
    home = Path.home()
    if sys.platform == "darwin":
        return home / ".Trash"
    configured = os.environ.get("XDG_DATA_HOME")
    data_home = Path(configured).expanduser() if configured else home / ".local" / "share"
    if not data_home.is_absolute():
        data_home = home / ".local" / "share"
    return data_home / "Trash" / "files"


def secure_directory(path: Path) -> None:
    path.mkdir(parents=True, exist_ok=True, mode=0o700)
    path.chmod(0o700)


def prepare_trash(root: Path) -> None:
    if sys.platform == "darwin":
        root.mkdir(parents=True, exist_ok=True, mode=0o700)
        return
    secure_directory(root.parent)
    secure_directory(root.parent / "info")
    secure_directory(root)


def unique_destination(root: Path, name: str, reserved: set[Path]) -> Path:
    candidate = root / name
    if candidate not in reserved and not candidate.exists() and not candidate.is_symlink():
        return candidate
    source = Path(name)
    stamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S")
    for number in range(1, 10_000):
        candidate = root / f"{source.stem}-{stamp}-{number}{source.suffix}"
        if candidate not in reserved and not candidate.exists() and not candidate.is_symlink():
            return candidate
    raise RuntimeError(f"cannot allocate a Trash name for {name}")


@contextmanager
def trash_lock(root: Path):
    prepare_trash(root)
    descriptor = os.open(root / ".agent-trash.lock", os.O_CREAT | os.O_RDWR, 0o600)
    try:
        fcntl.flock(descriptor, fcntl.LOCK_EX)
        yield
    finally:
        fcntl.flock(descriptor, fcntl.LOCK_UN)
        os.close(descriptor)


def stage_trashinfo(source: Path, destination: Path) -> Path | None:
    if sys.platform == "darwin":
        return None
    info_dir = destination.parent.parent / "info"
    secure_directory(info_dir)
    deleted = datetime.now().strftime("%Y-%m-%dT%H:%M:%S")
    content = f"[Trash Info]\nPath={quote(str(source))}\nDeletionDate={deleted}\n"
    target = info_dir / f"{destination.name}.trashinfo"
    descriptor, raw_temp = tempfile.mkstemp(prefix=f".{target.name}.", dir=info_dir)
    temp = Path(raw_temp)
    try:
        with os.fdopen(descriptor, "w", encoding="utf-8") as handle:
            handle.write(content)
        temp.chmod(0o600)
        temp.replace(target)
    finally:
        if temp.exists():
            temp.unlink()
    return target


def move_to_trash(source: Path, destination: Path) -> None:
    info = stage_trashinfo(source, destination)
    try:
        shutil.move(str(source), str(destination))
    except Exception:
        if info:
            info.unlink(missing_ok=True)
        raise


def contains(path: Path, candidate: Path) -> bool:
    try:
        candidate.relative_to(path)
    except ValueError:
        return False
    return True


def guarded_source(raw: str, cwd: Path, root: Path) -> Path:
    source = Path(raw).expanduser()
    if not source.is_absolute():
        source = cwd / source
    source = Path(os.path.abspath(source))
    canonical = source.parent.resolve(strict=False) / source.name if source.is_symlink() else source.resolve(strict=False)
    home = Path.home().resolve(strict=False)
    trash = root.resolve(strict=False)
    protected = {Path("/"), home, trash}
    if canonical in protected or contains(canonical, trash) or contains(trash, canonical):
        raise ValueError(f"refusing protected path: {raw}")
    return source


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("paths", nargs="+")
    parser.add_argument("--allow-missing", action="store_true")
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    cwd = Path.cwd()
    root = trash_root()
    errors: list[str] = []
    sources: list[Path] = []

    for raw in args.paths:
        try:
            source = guarded_source(raw, cwd, root)
        except ValueError as exc:
            errors.append(str(exc))
            continue
        if not source.exists() and not source.is_symlink():
            if not args.allow_missing:
                errors.append(f"missing: {raw}")
            continue
        sources.append(source)

    if errors:
        for error in errors:
            print(f"agent-trash: {error}", file=sys.stderr)
        return 1

    if args.dry_run:
        for source in sources:
            print(f"would trash {source}")
        return 0

    with trash_lock(root):
        reserved: set[Path] = set()
        for source in sources:
            destination = unique_destination(root, source.name, reserved)
            reserved.add(destination)
            try:
                move_to_trash(source, destination)
            except OSError as exc:
                print(f"agent-trash: {source}: {exc}", file=sys.stderr)
                return 1
            print(f"trashed {source}")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
